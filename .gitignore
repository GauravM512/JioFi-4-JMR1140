# =========================================================================
# JioFi JMR1140 Firmware Modding Git Ignore Configuration
# =========================================================================

# Large Extracted Filesystems (rebuilt on-the-fly using patches)
/rootfs/
/rootfs.state
/metadata/rootfs.state

# Personal customizations (WPS WOL listener) - NOT COMMITTED
/rootfs/usr/bin/wps_listener.sh
/rootfs/etc/init.d/start_wps_listener
/rootfs/etc/rc5.d/S99start_wps_listener

# Personal compiled images output directory
/personal_builds/

# Realtek Driver Source Directory (documentation covers how to download/build)
/driver/

# Keep Release Binaries and Prebuilts
!/patched/*.ubi
!/patched/rtl8189es-custom.ko

# Temporary Virtualenvs and Tooling
/.tools/
/.venv/
/venv/
/ubi-venv/

# Ignore all firmware files by default EXCEPT the reference system UBI image
/firmware/*
!/firmware/mdm9607-sysfs.ubi

# Windows Upgrade Tool Logs & Dumps
/firmware/LOG/
/firmware/*.log
*.log

# Editor & System Junk
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/

firmware_reverse_engineering