#!/bin/sh
# /etc/init.d/dropbear
# Starts Dropbear SSH daemon

KEY_DIR="/data/dropbear"
mkdir -p "$KEY_DIR"

case "$1" in
  start)
    echo -n "Starting Dropbear SSH: "
    # Generate host keys in persistent storage if not present
    if [ ! -f "$KEY_DIR/dropbear_rsa_host_key" ]; then
        dropbearkey -t rsa -f "$KEY_DIR/dropbear_rsa_host_key" -s 2048 >/dev/null 2>&1
    fi
    # Start Dropbear pointing to persistent key and writable PID file
    /usr/sbin/dropbear -B -r "$KEY_DIR/dropbear_rsa_host_key" -P /tmp/dropbear.pid
    echo "done"
    ;;
  stop)
    echo -n "Stopping Dropbear SSH: "
    killall dropbear 2>/dev/null
    echo "done"
    ;;
  restart)
    $0 stop
    $0 start
    ;;
  *)
    echo "Usage: $0 {start|stop|restart}"
    exit 1
    ;;
esac

exit 0
