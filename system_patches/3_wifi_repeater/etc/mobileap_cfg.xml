<system xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="mobileap_cfg.xsd">
	<MobileAPCfg>
		<MobileAPNatCfg>
			<Firewall>/etc/mobileap_firewall.xml</Firewall>
			<NatEntryGenericTimeout>200</NatEntryGenericTimeout>
			<NatEntryICMPTimeout>30</NatEntryICMPTimeout>
			<NatEntryTCPEstablishedTimeout>3600</NatEntryTCPEstablishedTimeout>
			<NatEntryUDPTimeout>60</NatEntryUDPTimeout>
			<DmzIP>0.0.0.0</DmzIP>
			<EnableIPSECVpnPassthrough>1</EnableIPSECVpnPassthrough>
			<EnablePPTPVpnPassthrough>1</EnablePPTPVpnPassthrough>
			<EnableL2TPVpnPassthrough>1</EnableL2TPVpnPassthrough>
			<EnableWebserverWWANAccess>0</EnableWebserverWWANAccess>
			<NATType>PRC</NATType>
			<ALGCfg>
				<EnableRTSPAlg>0</EnableRTSPAlg>
				<EnableSIPAlg>1</EnableSIPAlg>
			</ALGCfg>
		</MobileAPNatCfg>
		<MobileAPLanCfg>
			<Module>qca6174</Module>
			<EnableIPV4>1</EnableIPV4>
			<EnableIPV6>1</EnableIPV6>
			<GatewayURL>mobileap.qualcomm.com</GatewayURL>
			<WlanMode>AP</WlanMode>
			<WlanRestartDelay>1</WlanRestartDelay>
			<MobileAPSTABridgeEnable>0</MobileAPSTABridgeEnable>
			<HostAPDCfg>/tmp/hostapd.conf</HostAPDCfg>
				<HostAPDEntropy>/etc/entropy_file</HostAPDEntropy>
			<STAModeHostAPDCfg>/etc/sta_mode_hostapd.conf</STAModeHostAPDCfg>
			<APIPAddr>192.168.225.1</APIPAddr>
			<SubNetMask>255.255.255.0</SubNetMask>
			<EnableDHCPServer>1</EnableDHCPServer>
			<DHCPCfg>
				<StartIP>192.168.225.20</StartIP>
				<EndIP>192.168.225.60</EndIP>
				<LeaseTime>43200</LeaseTime>
			</DHCPCfg>
			<IPPassthroughCfg>
				<IPPassthroughEnable>0</IPPassthroughEnable>
				<IPPassthroughDeviceType>-1</IPPassthroughDeviceType>
				<IPPassthroughHostName>0</IPPassthroughHostName>
				<IPPassthroughMacAddr>0</IPPassthroughMacAddr>
			</IPPassthroughCfg>
			<GuestAPCfg>
				<HostAPDCfg>/etc/hostapd-wlan1.conf</HostAPDCfg>
					<HostAPDEntropy>/etc/entropy_file1</HostAPDEntropy>
				<AccessProfile>INTERNETONLY</AccessProfile>
			</GuestAPCfg>
			<StationModeCfg>
				<SupplicantCfg>/etc/wpa_supplicant.conf</SupplicantCfg>
				<STAModeConnType>1</STAModeConnType>
				<StaticIPAddr>0</StaticIPAddr>
				<StaticConfigDNSAddr>0</StaticConfigDNSAddr>
				<StaticConfigGWAddr>0</StaticConfigGWAddr>
				<StaticConfigNetMask>0</StaticConfigNetMask>
			</StationModeCfg>
		</MobileAPLanCfg>
		<MobileAPWanCfg>
			<AutoConnect>1</AutoConnect>
			<Roaming>1</Roaming>
			<EriConfig>/etc/mobileap_eri_config.bin</EriConfig>
			<FirstPreferredBackhaul>wwan</FirstPreferredBackhaul>
			<SecondPreferredBackhaul>wlan</SecondPreferredBackhaul>
			<ThirdPreferredBackhaul>usb_cradle</ThirdPreferredBackhaul>
			<FourthPreferredBackhaul>eth</FourthPreferredBackhaul>
			<TECH>ANY</TECH>
			<V4_UMTS_PROFILE_INDEX>0</V4_UMTS_PROFILE_INDEX>
			<V4_CDMA_PROFILE_INDEX>0</V4_CDMA_PROFILE_INDEX>
			<V6_UMTS_PROFILE_INDEX>0</V6_UMTS_PROFILE_INDEX>
			<V6_CDMA_PROFILE_INDEX>0</V6_CDMA_PROFILE_INDEX>
			<DefaultSIPServerConfigType>FQDN</DefaultSIPServerConfigType>
			<DefaultSIPServerConfig>abcd.com</DefaultSIPServerConfig>
			<PrefixDelegation>0</PrefixDelegation>
		</MobileAPWanCfg>
		<MobileAPSrvcCfg>
			<UPnP>0</UPnP>
			<DLNA>0</DLNA>
			<MDNS>0</MDNS>
			<DLNAWhitelistingAllow>0</DLNAWhitelistingAllow>
		</MobileAPSrvcCfg>
		<DDNSCfg>
			<EnableDDNS>0</EnableDDNS>
			<DDNSServer>members.dyndns.org</DDNSServer>
			<DDNSProtocol>dyndns2</DDNSProtocol>
			<DDNSLogin>ddclient</DDNSLogin>
			<DDNSPassword>DYNdns123</DDNSPassword>
			<DDNSHostname>mobileap.dyndns.org</DDNSHostname>
			<DDNSTimeout>60</DDNSTimeout>
		</DDNSCfg>
		<TinyProxyCfg>
			<EnableTinyProxy>0</EnableTinyProxy>
		</TinyProxyCfg>
		<Dhcpv6Cfg>
				<EnableDhcpv6Dns>1</EnableDhcpv6Dns>
		</Dhcpv6Cfg>
		<MobileAPBootUpCfg>
			<MobileAPEnableAtBootup>1</MobileAPEnableAtBootup>
			<WLANEnableAtBootup>1</WLANEnableAtBootup>
		</MobileAPBootUpCfg>
		<Cradle>
			<CradleMode>2</CradleMode>
		</Cradle>
		<!-- 201603xx.knkim.add [start] -->
		<AmtCfg>
			<PrimaryDNS>192.168.225.1</PrimaryDNS>
			<SecondaryDNS>0.0.0.0</SecondaryDNS>
			<V46_MTUSize>1500</V46_MTUSize>
			<APN4NetworkAttach>1</APN4NetworkAttach>
			<APN>internet</APN>
			<TCPBindingTime>3600</TCPBindingTime>
			<UDPBindingTime>60</UDPBindingTime>
			<EnableAllowIcmpRedirect>0</EnableAllowIcmpRedirect>
			<EnableAllowPingFromWwan>0</EnableAllowPingFromWwan>
			<EnableWebserverWWANAccessPort>80</EnableWebserverWWANAccessPort>
			<ManagementSessionTimeout>600</ManagementSessionTimeout>
			<GUIRefreshTime>10</GUIRefreshTime>
			<EnableLog>1</EnableLog>
			<MacFilter>
				<MACFilterEnable>0</MACFilterEnable>
				<MACFilterRestrictMode>0</MACFilterRestrictMode>
			</MacFilter>
			<wifi>
				<SSID>JMR1140</SSID>
				<Mode_802_11>11bgn</Mode_802_11>
				<TX_Power>15</TX_Power>
				<Beacon_int>100</Beacon_int>
				<WPS>1</WPS>
				<SEC_Mode>WPA2PSK</SEC_Mode>
				<Encryption_type>AES</Encryption_type>
				<SEC_Key>1234567890</SEC_Key>
				<WEP_Key1>0</WEP_Key1>
				<WEP_Key2>0</WEP_Key2>
				<WEP_Key3>0</WEP_Key3>
				<WEP_Key4>0</WEP_Key4>
				<WEP_Key_Selection>0</WEP_Key_Selection>
				<Channel>0</Channel>
				<Sleep_Timer>30</Sleep_Timer>
				<SSID_Broadcast>1</SSID_Broadcast>
				<Wifi_OnOff>1</Wifi_OnOff>
				<WMM_Enable>1</WMM_Enable>
			</wifi>
			<GatewayUrl>
				<url_list>embms.jio.local</url_list>
				<url_list>jiomifi.local.html</url_list>
				<url_list>jiofi.local.html</url_list>
			</GatewayUrl>
			<Storage>
				<Account>0</Account>
				<Mode>0</Mode>
				<Username>jio</Username>
				<Password>jiofi</Password>
			</Storage>
			<PortFWList>
			</PortFWList>
		</AmtCfg>
		<!-- 201603xx.knkim.add [end] -->
	</MobileAPCfg>
</system>
